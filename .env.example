# LLM Provider Configuration
# Options: groq, openai
LLM_PROVIDER=groq
GROQ_API_KEY=your_groq_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
LLM_MODEL=mixtral-8x7b-32768

# Document Processing
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Retrieval Settings
TOP_K=5
SIMILARITY_THRESHOLD=0.3

# Agent Settings
MAX_ITERATIONS=5
AGENT_TIMEOUT=60
USE_QUERY_REWRITING=true
USE_RE_RANKING=true

# Vector Database
VECTORDB_TYPE=faiss
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# LLM Parameters
TEMPERATURE=0.3
MAX_TOKENS=2000
